# MIME για βίντεο (πολλά shared hosting σερβίρουν λάθος τύπο χωρίς αυτό)
<IfModule mod_mime.c>
    AddType video/mp4 .mp4
    AddType video/webm .webm
</IfModule>

# Βοηθάει streaming μεγάλων mp4 (όπου υποστηρίζεται)
<IfModule mod_headers.c>
    <FilesMatch "\.(mp4|webm)$">
        Header set Accept-Ranges bytes
    </FilesMatch>
</IfModule>

# Καθαρά URLs: παλιά .html → φάκελος/
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^biografiko\.html$ /biografiko/ [R=301,L]
    RewriteRule ^epikoinonia\.html$ /epikoinonia/ [R=301,L]
    RewriteRule ^oroi-xrisis\.html$ /oroi-xrisis/ [R=301,L]
    RewriteRule ^politiki-aporittou\.html$ /politiki-aporittou/ [R=301,L]
</IfModule>
